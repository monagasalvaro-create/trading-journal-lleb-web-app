# Dependencies — always re-installed inside the container
**/node_modules

# Build output — rebuilt inside container
frontend/dist

# Python cache
**/__pycache__
**/*.pyc
**/*.pyo

# Database files
*.db
*.sqlite3

# Local env files — never bake secrets into image
.env
.env.*
!.env.example

# Git & editor
.git
.gitignore
**/.DS_Store

# Test artifacts
backend/tests/__pycache__
.pytest_cache
