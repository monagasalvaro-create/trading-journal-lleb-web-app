# ─── Environment Variables ───────────────────────────────────────────────────
# Copy this file to .env and fill in the values before running the backend.
# Never commit the actual .env file to version control.

# PostgreSQL connection string — REQUIRED. Backend fails to start if missing.
# Dev via docker-compose:
#   DATABASE_URL=postgresql+asyncpg://tj:tj@localhost:5432/trading_journal
# Railway (prod): the Postgres addon injects DATABASE_URL automatically.
DATABASE_URL=postgresql+asyncpg://tj:tj@localhost:5432/trading_journal

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-64-character-random-string-here

# Fernet encryption key for IBKR Flex Token storage
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here

# Application environment
ENVIRONMENT=production

# CORS allowed origins (comma-separated, no spaces)
# Example: https://app.tudominio.com,https://www.tudominio.com
ALLOWED_ORIGINS=https://app.tudominio.com
