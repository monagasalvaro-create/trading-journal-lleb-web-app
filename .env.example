# ─── Production Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in the values before deploying.
# Never commit the actual .env file to version control.

# PostgreSQL connection string (production)
# Format: postgresql+asyncpg://user:password@host:5432/database_name
DATABASE_URL=postgresql+asyncpg://trading_user:your_secure_password@localhost:5432/trading_journal

# Leave blank to use SQLite in development (default fallback in database.py)
# DATABASE_URL=

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-64-character-random-string-here

# Fernet encryption key for IBKR Flex Token storage
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here

# Application environment
ENVIRONMENT=production

# CORS allowed origins (comma-separated, no spaces)
# Example: https://app.tudominio.com,https://www.tudominio.com
ALLOWED_ORIGINS=https://app.tudominio.com
