{
  "name": "tj-bridge",
  "version": "0.4.0",
  "description": "Local bridge between Trading Journal web app and Interactive Brokers TWS/Gateway. Read-only, runs on 127.0.0.1:8765.",
  "main": "src/index.js",
  "bin": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js",
    "build": "pkg . --out-path build",
    "build:win": "pkg . --targets node18-win-x64 --out-path build",
    "build:mac": "pkg . --targets node18-macos-x64,node18-macos-arm64 --out-path build"
  },
  "pkg": {
    "targets": [
      "node18-win-x64",
      "node18-macos-x64",
      "node18-macos-arm64"
    ],
    "outputPath": "build",
    "assets": []
  },
  "dependencies": {
    "@stoqey/ib": "^1.3.21",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "rxjs": "^7.8.1"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@yao-pkg/pkg": "^6.19.0"
  }
}
